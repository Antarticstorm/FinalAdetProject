-- ============================================================
-- The Literary Nook — full database setup
-- Use this ONE file for a brand new, empty database.
-- In phpMyAdmin: select the bookstore_db database > Import > choose this file > Go
-- Or via command line:
--   cd C:\xampp\mysql\bin
--   mysql -u root bookstore_db < "C:\xampp\htdocs\FinalAdetProject-updated\sql\full_setup.sql"
-- ============================================================

-- 1. Customers (registration, login, profile, password reset all use these columns)
CREATE TABLE IF NOT EXISTS customers (
    id INT AUTO_INCREMENT PRIMARY KEY,
    fullname VARCHAR(100) NOT NULL,
    email VARCHAR(150) NOT NULL UNIQUE,
    phone VARCHAR(30) NOT NULL,
    address TEXT NOT NULL,
    password VARCHAR(255) NOT NULL,
    role ENUM('customer','admin') NOT NULL DEFAULT 'customer',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB;

-- 2. Password reset tokens (used by forgot_password.php / reset_password.php)
CREATE TABLE IF NOT EXISTS password_resets (
    id INT AUTO_INCREMENT PRIMARY KEY,
    customer_id INT NOT NULL,
    token VARCHAR(64) NOT NULL UNIQUE,
    expires_at DATETIME NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (customer_id) REFERENCES customers(id) ON DELETE CASCADE
) ENGINE=InnoDB;

-- 3. Books (admin add_book.php / books.php, and the new shop.php)
--    discount_percent is included here directly since this is a fresh table.
CREATE TABLE IF NOT EXISTS books (
    id INT AUTO_INCREMENT PRIMARY KEY,
    title VARCHAR(150) NOT NULL,
    author VARCHAR(100) NOT NULL,
    isbn VARCHAR(30) DEFAULT NULL,
    genre VARCHAR(50) DEFAULT NULL,
    publication_year INT DEFAULT NULL,
    publisher VARCHAR(100) DEFAULT NULL,
    format VARCHAR(30) DEFAULT NULL,
    price DECIMAL(10,2) NOT NULL,
    discount_percent DECIMAL(5,2) NOT NULL DEFAULT 0,
    stock INT NOT NULL DEFAULT 0,
    description TEXT,
    cover VARCHAR(255) DEFAULT 'uploads/covers/default.webp'
) ENGINE=InnoDB;

-- 4. Promo / coupon codes (site-wide promotional offers applied at checkout)
CREATE TABLE IF NOT EXISTS promo_codes (
    id INT AUTO_INCREMENT PRIMARY KEY,
    code VARCHAR(30) NOT NULL UNIQUE,
    description VARCHAR(150) DEFAULT NULL,
    discount_percent DECIMAL(5,2) DEFAULT NULL,
    discount_amount DECIMAL(10,2) DEFAULT NULL,
    is_active TINYINT(1) NOT NULL DEFAULT 1,
    expires_at DATE DEFAULT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB;

